# Copy to .env and fill in values before running docker compose

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=progressgrader
POSTGRES_USER=pg
POSTGRES_PASSWORD=changeme

# ── Gitea DB (uses same postgres instance, separate DB) ───────────────────────
GITEA_DB=gitea

# ── Platform domains ──────────────────────────────────────────────────────────
PLATFORM_DOMAIN=localhost
GITEA_DOMAIN=gitea.localhost

# ── Secrets (generate with: openssl rand -hex 32) ────────────────────────────
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
ENCRYPTION_KEY=changeme_generate_with_python_cryptography_fernet_generate_key
GITEA_WEBHOOK_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── Gitea admin token (created after first Gitea startup) ────────────────────
GITEA_ADMIN_TOKEN=

# ── Minio ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=workspace-archives

# ── AI Provider defaults (students/projects can override) ────────────────────
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o
DEFAULT_API_KEY=
DEFAULT_BASE_URL=
